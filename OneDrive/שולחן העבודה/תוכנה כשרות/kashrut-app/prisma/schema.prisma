generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  nameEn    String?
  logo      String?
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  clients             Client[]
  sites               Site[]
  products            Product[]
  mashgichim          Mashgiach[]
  certBodies          CertBody[]
  dealers             Dealer[]
  projects            Project[]
  assignments         Assignment[]
  certificates        Certificate[]
  invoices            Invoice[]
  quotes              Quote[]
  holograms           HologramBatch[]
  hologramTransfers   HologramTransfer[]
  alerts              Alert[]
  checklistTemplates  ProjectChecklistTemplate[]
  profileEditRequests ProfileEditRequest[]
  officeMessages      OfficeMessage[]
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String
  email        String @unique
  passwordHash String?
  role         Role

  // Fine-grained permissions for office staff
  canManageClients      Boolean @default(false)
  canManageFinance      Boolean @default(false)
  canManageCertificates Boolean @default(false)
  canManageSalary       Boolean @default(false)
  canManageScheduling   Boolean @default(false)
  canManageHolograms    Boolean @default(false)
  canViewReports        Boolean @default(false)
  canManageSettings     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  activityLogs ActivityLog[]
  mashgiach    Mashgiach?
}

enum Role {
  ADMIN
  OFFICE_STAFF
  MASHGIACH
  RABBI
  IMPORTER_PORTAL
  BUSINESS_PORTAL
}

// ─── Clients ──────────────────────────────────────────────────────────────────

model Client {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  nameEn      String?
  type        ClientType
  vatNumber   String?
  contactName String?
  phone       String?
  email       String?
  address     String?

  certRelease   CertRelease @default(IMMEDIATE)
  requiresQuote Boolean     @default(false)

  defaultDealerId String?
  defaultDealer   Dealer?  @relation("ClientDefaultDealer", fields: [defaultDealerId], references: [id])

  // ── Billing settings ──────────────────────────────────────────────────────
  billingSource          BillingSource     @default(IMPORTER)
  agentCommissionDealerId String?
  agentCommissionType    CommissionType    @default(NONE)
  agentCommissionValue   Float?

  annualFee         Float?
  annualFeeCurrency Currency @default(ILS)

  billingNotes String?

  portalToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sites        Site[]
  projects     Project[]
  certificates Certificate[]
  invoices     Invoice[]
  quotes       Quote[]
  activityLogs ActivityLog[]
  priceItems   ClientPriceItem[]
}

enum BillingSource {
  IMPORTER
  AGENT
  FACTORY
}

enum CommissionType {
  NONE
  PERCENTAGE
  FIXED
}

enum Currency {
  ILS
  USD
  EUR
  GBP
}

model ClientPriceItem {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name      String
  unitLabel String?
  price     Float
  currency  Currency @default(USD)
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectLineItems ProjectLineItem[]
}

enum ClientType {
  IMPORTER
  BUSINESS
  BOTH
}

enum CertRelease {
  IMMEDIATE
  AFTER_PAYMENT
}

// ─── Sites (מפעלים/עסקים) ────────────────────────────────────────────────────

model Site {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])

  name     String
  nameEn   String?
  type     SiteType
  address  String?
  country  String
  timezone String

  latitude  Float?
  longitude Float?

  contactName String?
  phone       String?
  email       String?
  language    String?

  internalReport    Boolean @default(true)
  rabbinateReport   Boolean @default(false)
  rabbinateTemplate String?

  accessToken String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products         Product[]
  productionPoints ProductionPoint[]
  projects         Project[]
  assignments      Assignment[]
  activityLogs     ActivityLog[]
  productSites     ProductSite[]
  projectSites     ProjectSite[]
  contacts         SiteContact[]
}

model SiteContact {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  name      String
  role      String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SiteType {
  FACTORY
  RESTAURANT
  HOTEL
  BAKERY
  WAREHOUSE
  OTHER
}

model ProductionPoint {
  id     String @id @default(cuid())
  siteId String
  site   Site   @relation(fields: [siteId], references: [id])

  name      String
  latitude  Float?
  longitude Float?
  notes     String?

  createdAt DateTime @default(now())

  mashgichim ProductionPointMashgiach[]
}

model ProductionPointMashgiach {
  productionPointId String
  productionPoint   ProductionPoint @relation(fields: [productionPointId], references: [id])
  mashgiachId       String
  mashgiach         Mashgiach       @relation(fields: [mashgiachId], references: [id])

  @@id([productionPointId, mashgiachId])
}

// ─── Products ─────────────────────────────────────────────────────────────────

model Product {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])
  clientId       String

  name     String
  nameEn   String?
  category String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certBodyProducts CertBodyProduct[]
  rawMaterials     RawMaterial[]
  labelApprovals   LabelApproval[]
  projectProducts  ProjectProduct[]
  productSites     ProductSite[]
}

// ─── Certifying Bodies ────────────────────────────────────────────────────────

model CertBody {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name         String
  nameEn       String?
  logo         String?
  country      String?
  contactName  String?
  contactEmail String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())

  certBodyProducts     CertBodyProduct[]
  mashgiachCertBodies  MashgiachCertBody[]
  projects             Project[]
  certificates         Certificate[]
  hologramBatches      HologramBatch[]
  rawMaterialApprovals RawMaterialApproval[]
}

model CertBodyProduct {
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  certBodyId String
  certBody   CertBody @relation(fields: [certBodyId], references: [id])

  requirements String[]

  @@id([productId, certBodyId])
}

// ─── Raw Materials & Labels ───────────────────────────────────────────────────

model RawMaterial {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name            String
  supplier        String?
  country         String?
  certBodyId      String?
  status          RawMaterialStatus @default(PENDING)
  certificateFile String?

  kosherType          KosherType @default(PAREVE)
  certificateIssuedBy String?

  imageUrl        String?
  requiresKosherSymbol Boolean @default(false)
  factorySpecific      Boolean @default(false)

  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  expiresAt      DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  approvals RawMaterialApproval[]
}

model RawMaterialApproval {
  id            String      @id @default(cuid())
  rawMaterialId String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  certBodyId    String
  certBody      CertBody    @relation(fields: [certBodyId], references: [id])

  status     RawMaterialStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  expiresAt  DateTime?
  notes      String?

  yearRound            Boolean @default(true)
  passover             Boolean @default(false)
  kitniyot             Boolean @default(false)
  classificationOverride String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rawMaterialId, certBodyId])
}

enum RawMaterialStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  EXPIRED
  NEEDS_INFO
}

enum KosherType {
  PAREVE
  DAIRY
  MEAT
}

model LabelApproval {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  version    Int            @default(1)
  fileUrl    String?
  notes      String?
  status     ApprovalStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?

  createdAt DateTime @default(now())
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  NEEDS_CHANGES
}

// ─── Mashgichim ───────────────────────────────────────────────────────────────

model Mashgiach {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name          String
  nameEn        String?
  phone         String?
  email         String?
  city          String?
  passportPhoto String?
  citizenships  String[]
  languages     Json?
  activeRegions String[]

  salaryModel   SalaryModel?
  salaryRate    Float?
  expensesType  ExpensesType?
  fixedExpenses Float?
  notes         String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certBodies           MashgiachCertBody[]
  levels               MashgiachLevel[]
  assignments          Assignment[]
  productionPoints     ProductionPointMashgiach[]
  payrollEntries       PayrollEntry[]
  hologramTransfersOut HologramTransfer[] @relation("TransferFrom")
  hologramTransfersIn  HologramTransfer[] @relation("TransferTo")
  profileEditRequests  ProfileEditRequest[]
  officeMessages       OfficeMessage[]

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])
}

model ProfileEditRequest {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  mashgiachId    String
  mashgiach      Mashgiach    @relation(fields: [mashgiachId], references: [id])

  requestType String  // "CHANGE" | "ADD"
  field       String  // "phone" | "email" | "city" | "nameEn"
  oldValue    String?
  newValue    String
  extraData   String? // JSON for complex fields (e.g. language level)

  status     String   @default("PENDING") // "PENDING" | "APPROVED" | "REJECTED"
  adminNotes String?
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?
}

enum SalaryModel {
  HOURLY
  DAILY
  MONTHLY
  COMBINED
}

enum ExpensesType {
  NONE
  FIXED
  VARIABLE
  BOTH
}

model MashgiachCertBody {
  mashgiachId String
  mashgiach   Mashgiach @relation(fields: [mashgiachId], references: [id])
  certBodyId  String
  certBody    CertBody  @relation(fields: [certBodyId], references: [id])

  @@id([mashgiachId, certBodyId])
}

model SupervisionLevel {
  id             String @id @default(cuid())
  organizationId String

  name     String
  nameEn   String?
  color    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  mashgichim MashgiachLevel[]
}

model MashgiachLevel {
  mashgiachId String
  mashgiach   Mashgiach        @relation(fields: [mashgiachId], references: [id])
  levelId     String
  level       SupervisionLevel @relation(fields: [levelId], references: [id])

  @@id([mashgiachId, levelId])
}

// ─── Dealers ──────────────────────────────────────────────────────────────────

model Dealer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  name        String
  contactName String?
  phone       String?
  email       String?
  notes       String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects        Project[]
  defaultForClients Client[] @relation("ClientDefaultDealer")
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model Project {
  id             String       @id @default(cuid())
  projectNumber  Int          @unique @default(autoincrement())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])
  certBodyId     String?
  certBody       CertBody?    @relation(fields: [certBodyId], references: [id])
  dealerId       String?
  dealer         Dealer?      @relation(fields: [dealerId], references: [id])

  type               ProjectType
  status             ProjectStatus      @default(PENDING)
  dealerBillingModel DealerBillingModel?

  openedAt         DateTime  @default(now())
  plannedVisitAt   DateTime?
  plannedVisitEnd  DateTime?
  actualVisitAt    DateTime?
  completedAt      DateTime?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products             ProjectProduct[]
  assignments          Assignment[]
  certificates         Certificate[]
  invoices             Invoice[]
  quotes               Quote[]
  activityLogs         ActivityLog[]
  projectSites         ProjectSite[]
  checklistItems       ProjectChecklistItem[]
  hologramAllocations  HologramAllocation[]
  lineItems            ProjectLineItem[]
}

model ProjectLineItem {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  priceItemId String?
  priceItem   ClientPriceItem? @relation(fields: [priceItemId], references: [id])

  description String
  quantity    Float    @default(1)
  unitPrice   Float
  currency    Currency @default(USD)
  notes       String?
  order       Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectType {
  ANNUAL
  LAB
  SPECIFIC
}

enum ProjectStatus {
  PENDING
  ACTIVE
  COMPLETED
  APPROVED
  CERTIFIED
}

enum DealerBillingModel {
  FIXED_PRICE
  EXPENSE_REPORT
}

model ProjectProduct {
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])

  @@id([projectId, productId])
}

// Secondary production sites linked to a product (e.g. dairies for a dairy product)
model ProductSite {
  productId String
  product   Product @relation(fields: [productId], references: [id])
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id])
  notes     String?

  createdAt DateTime @default(now())

  @@id([productId, siteId])
}

// Sites selected to participate in a specific project (chosen from ProductSite list)
model ProjectSite {
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id])

  createdAt DateTime @default(now())

  @@id([projectId, siteId])
}

// ─── Project Checklist ────────────────────────────────────────────────────────

// Org-level checklist item definitions (configurable in settings)
model ProjectChecklistTemplate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  label    String
  order    Int     @default(0)
  isActive Boolean @default(true)
  category String? // e.g. "חלב" — optional filter/grouping tag

  createdAt DateTime @default(now())

  projectItems ProjectChecklistItem[]
}

// Per-project completion state for each checklist step
model ProjectChecklistItem {
  id         String                   @id @default(cuid())
  projectId  String
  project    Project                  @relation(fields: [projectId], references: [id])
  templateId String
  template   ProjectChecklistTemplate @relation(fields: [templateId], references: [id])

  isCompleted Boolean   @default(false)
  completedAt DateTime?
  completedBy String?

  @@unique([projectId, templateId])
}

// ─── Assignments (שיבוץ) ──────────────────────────────────────────────────────

model Assignment {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  siteId         String
  site           Site         @relation(fields: [siteId], references: [id])
  mashgiachId    String
  mashgiach      Mashgiach    @relation(fields: [mashgiachId], references: [id])

  type   VisitType
  status AssignmentStatus @default(CREATED)

  scheduledAt  DateTime
  scheduledEnd DateTime?
  actualStart  DateTime?
  actualEnd    DateTime?

  startLatitude  Float?
  startLongitude Float?
  endLatitude    Float?
  endLongitude   Float?

  siteArrangesTravel Boolean @default(false)
  travelDetails      String?
  instructions       String?

  siteConfirmedAt  DateTime?
  siteConfirmToken String?   @unique

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports      AssignmentReport[]
  activityLogs ActivityLog[]
}

enum VisitType {
  ANNUAL
  SPECIFIC
  CONTINUOUS
  INITIAL
}

enum AssignmentStatus {
  CREATED
  SITE_CONFIRMED
  DEPARTED
  ARRIVED
  COMPLETED
  REPORTED
  APPROVED
}

model AssignmentReport {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])

  checkIn  DateTime?
  checkOut DateTime?

  internalNotes  String?
  rabbinateNotes String?
  findings       String?
  issues         String?

  hologramFrom Int?
  hologramTo   Int?

  signature String?
  status    ReportStatus @default(DRAFT)

  copiedFromId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// ─── Holograms ────────────────────────────────────────────────────────────────

model HologramBatch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  certBodyId String?
  certBody   CertBody? @relation(fields: [certBodyId], references: [id])

  rangeFrom  Int
  rangeTo    Int
  receivedAt DateTime @default(now())
  notes      String?

  allocations HologramAllocation[]
  transfers   HologramTransfer[]
}

model HologramAllocation {
  id        String        @id @default(cuid())
  batchId   String
  batch     HologramBatch @relation(fields: [batchId], references: [id])
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])

  rangeFrom   Int
  rangeTo     Int
  allocatedAt DateTime @default(now())

  usages HologramUsage[]
}

model HologramUsage {
  id           String             @id @default(cuid())
  allocationId String
  allocation   HologramAllocation @relation(fields: [allocationId], references: [id])

  rangeFrom Int
  rangeTo   Int
  usedAt    DateTime @default(now())
  reportId  String?
}

model HologramTransfer {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  batchId String
  batch   HologramBatch @relation(fields: [batchId], references: [id])

  rangeFrom Int
  rangeTo   Int

  fromType       TransferParty
  fromMashgiachId String?
  fromMashgiach   Mashgiach?    @relation("TransferFrom", fields: [fromMashgiachId], references: [id])

  toType         TransferParty
  toMashgiachId  String?
  toMashgiach    Mashgiach?    @relation("TransferTo", fields: [toMashgiachId], references: [id])

  status      TransferStatus @default(PENDING)
  notes       String?
  sentAt      DateTime       @default(now())
  confirmedAt DateTime?
  rejectedAt  DateTime?
}

enum TransferParty {
  ORG
  MASHGIACH
}

enum TransferStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

// ─── Certificates ─────────────────────────────────────────────────────────────

model Certificate {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id])
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id])
  certBodyId     String?
  certBody       CertBody?    @relation(fields: [certBodyId], references: [id])

  issuedAt  DateTime @default(now())
  expiresAt DateTime

  status CertificateStatus @default(ISSUED)

  pdfUrl  String?
  wordUrl String?

  sentAt   DateTime?
  sentVia  String?
  sentTo   String?

  renewalAlertSent Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CertificateStatus {
  ISSUED
  WAITING_PAYMENT
  READY_TO_SEND
  SENT
  SENT_MANUALLY
}

// ─── Finance ──────────────────────────────────────────────────────────────────

model Quote {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])

  items      Json
  total      Float
  status     QuoteStatus @default(PENDING)
  validUntil DateTime?
  terms      String?

  approvedAt     DateTime?
  approvedByName String?
  approvalToken  String?   @unique

  invoiceId String?

  sentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuoteStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
  EXPIRED
}

model Invoice {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id])
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id])

  number     String
  items      Json
  total      Float
  status     InvoiceStatus @default(PENDING)
  dueDate    DateTime?
  paidAt     DateTime?
  paidAmount Float?

  sentAt  DateTime?
  sentVia String?

  releaseCertOnPayment Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
}

model PayrollEntry {
  id          String    @id @default(cuid())
  mashgiachId String
  mashgiach   Mashgiach @relation(fields: [mashgiachId], references: [id])

  month       Int
  year        Int
  hoursWorked Float?
  baseAmount  Float
  expenses    Float         @default(0)
  total       Float
  status      PayrollStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?

  createdAt DateTime @default(now())
}

enum PayrollStatus {
  PENDING
  APPROVED
  PAID
}

// ─── Activity Log ─────────────────────────────────────────────────────────────

model ActivityLog {
  id             String @id @default(cuid())
  organizationId String

  entityType  String
  entityId    String
  action      String
  description String
  metadata    Json?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id])
  siteId       String?
  site         Site?       @relation(fields: [siteId], references: [id])
  assignmentId String?
  assignment   Assignment? @relation(fields: [assignmentId], references: [id])

  createdAt DateTime @default(now())
}

// ─── Alerts ───────────────────────────────────────────────────────────────────

model Alert {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  type        AlertType
  severity    AlertSeverity
  title       String
  description String?
  entityType  String?
  entityId    String?

  isRead       Boolean   @default(false)
  isDismissed  Boolean   @default(false)
  snoozedUntil DateTime?

  createdAt DateTime @default(now())
}

// ─── Office Messages (Mashgiach → Office) ─────────────────────────────────────

model OfficeMessage {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  mashgiachId    String
  mashgiach      Mashgiach    @relation(fields: [mashgiachId], references: [id])

  body        String
  attachments Json?    // string[] of relative file paths under /uploads/messages/

  status  String   @default("UNREAD") // UNREAD | READ
  readAt  DateTime?
  readBy  String?

  createdAt DateTime @default(now())
}

enum AlertType {
  CERT_EXPIRING
  CERT_NOT_SENT
  MASHGIACH_LATE
  REPORT_NOT_SUBMITTED
  PAYMENT_OVERDUE
  QUOTE_EXPIRING
  HOLOGRAM_LOW
  RAW_MATERIAL_EXPIRED
  PROFILE_CHANGE_REQUEST
  OFFICE_MESSAGE
}

enum AlertSeverity {
  URGENT
  IMPORTANT
  INFO
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
