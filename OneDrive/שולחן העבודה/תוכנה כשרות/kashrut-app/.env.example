# PostgreSQL — ספק Railway/Neon/Supabase יתן את הכתובת
DATABASE_URL="postgresql://user:password@host:5432/kashrut_db?schema=public"

# NextAuth — צור עם: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_URL="https://your-app.railway.app"

# Google Maps (אופציונלי)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# WhatsApp — Green API (אופציונלי)
GREEN_API_INSTANCE=""
GREEN_API_TOKEN=""

# Twilio SMS (אופציונלי)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
